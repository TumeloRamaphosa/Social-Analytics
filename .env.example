# ===========================================
# STUDEX PLATFORM CONFIGURATION
# ===========================================
# Copy this to .env and fill in your values

# --- DATABASE ---
DATABASE_URL=mysql://user:password@localhost:3306/studex

# --- SHOPIFY (Studex Meat) ---
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxx

# --- FACEBOOK/META (Ads & Instagram) ---
META_ACCESS_TOKEN=xxxxx
META_PAGE_ID=xxxxx
META_AD_ACCOUNT_ID=xxxxx

# --- FIRECRAWL (Research) ---
FIRECRAWL_API_KEY=fc-xxxxx

# --- HIGGSFIELD (Video Generation) ---
HIGGSFIELD_API_KEY=hf_xxxxx

# --- OPENAI/ANTHROPIC (AI Models) ---
OPENAI_API_KEY=sk-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- BLOBATO (Multi-platform Posting) ---
BLOTATO_API_KEY=xxxxx

# --- GOOGLE DRIVE ---
GOOGLE_CLIENT_ID=xxxxx
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REFRESH_TOKEN=xxxxx

# --- AUTH (Session) ---
SESSION_SECRET=your-random-secret-min-32-chars

# --- RALF LOOP (Daily Automation) ---
RALF_CRON_SCHEDULE="0 0 * * *"  # Midnight daily